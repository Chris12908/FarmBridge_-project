generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Role {
  BUYER
  FARMER
  ADMIN
}

enum ListingStatus {
  DRAFT
  ACTIVE
  OUT_OF_STOCK
  EXPIRED
}

enum ProductCategory {
  VEGETABLES
  FRUITS
  GRAINS
  DAIRY
  LIVESTOCK
  POULTRY
  HERBS
  NUTS
  SEAFOOD
  OTHER
}

enum NegotiationStatus {
  INITIATED
  NEGOTIATING
  PRICE_PROPOSED
  BUYER_APPROVED
  BUYER_DECLINED
  CHECKED_OUT
  FULFILLED
}

enum MessageType {
  TEXT
  VOICE_NOTE
  IMAGE
  PRICE_PROPOSAL
  SYSTEM
}

enum ProposalStatus {
  PENDING
  ACCEPTED
  DECLINED
  COUNTERED
  EXPIRED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  DISPATCHED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  STRIPE
  FLUTTERWAVE_MPESA
  FLUTTERWAVE_MTN
  FLUTTERWAVE_ORANGE
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum NotificationType {
  NEW_MESSAGE
  PRICE_PROPOSAL
  OFFER_ACCEPTED
  OFFER_DECLINED
  ORDER_CONFIRMED
  ORDER_DISPATCHED
  ORDER_DELIVERED
  PAYMENT_RECEIVED
  REVIEW_REQUEST
  LISTING_EXPIRING
  SYSTEM
}

// ─────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String?
  googleId      String?  @unique
  role          Role     @default(BUYER)
  name          String
  phoneNumber   String?
  avatarUrl     String?
  isVerified    Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  farmerProfile      FarmerProfile?
  buyerProfile       BuyerProfile?
  addresses          Address[]
  products           Product[]
  buyerSessions      NegotiationSession[] @relation("BuyerSessions")
  farmerSessions     NegotiationSession[] @relation("FarmerSessions")
  sentMessages       ChatMessage[]        @relation("SentMessages")
  buyerOrders        Order[]              @relation("BuyerOrders")
  farmerOrders       Order[]              @relation("FarmerOrders")
  notifications      Notification[]
  reviews            Review[]
  refreshTokens      RefreshToken[]
  emailVerifications EmailVerification[]
  passwordResets     PasswordReset[]
  deviceTokens       DeviceToken[]

  @@map("users")
}

model FarmerProfile {
  id                  String   @id @default(uuid())
  userId              String   @unique
  bio                 String?
  farmName            String?
  farmLocation        String?
  latitude            Float?
  longitude           Float?
  crops               String[]
  tags                String[]
  verificationStatus  String   @default("UNVERIFIED")
  rating              Float    @default(0)
  reviewCount         Int      @default(0)
  completedOrderCount Int      @default(0)
  profileComplete     Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("farmer_profiles")
}

model BuyerProfile {
  id           String   @id @default(uuid())
  userId       String   @unique
  preferences  String[]
  location     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("buyer_profiles")
}

model Address {
  id         String   @id @default(uuid())
  userId     String
  label      String
  street     String
  city       String
  state      String
  country    String
  postalCode String?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@map("addresses")
}

model Product {
  id              String          @id @default(uuid())
  farmerId        String
  name            String
  description     String?
  category        ProductCategory
  pricePerUnit    Decimal         @db.Decimal(10, 2)
  unit            String
  quantityAvailable Int
  minimumOrder    Int             @default(1)
  images          String[]
  tags            String[]
  status          ListingStatus   @default(DRAFT)
  expiresAt       DateTime?
  viewCount       Int             @default(0)
  searchVector    Unsupported("tsvector")?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  farmer       User                 @relation(fields: [farmerId], references: [id], onDelete: Restrict)
  sessions     NegotiationSession[]

  @@index([farmerId])
  @@index([status])
  @@index([category])
  @@index([searchVector], type: Gin)
  @@map("products")
}

model NegotiationSession {
  id              String            @id @default(uuid())
  buyerId         String
  farmerId        String
  productId       String
  status          NegotiationStatus @default(INITIATED)
  agreedPrice     Decimal?          @db.Decimal(10, 2)
  agreedQuantity  Int?
  lastMessageAt   DateTime?
  lastMessagePreview String?
  buyerUnreadCount  Int             @default(0)
  farmerUnreadCount Int             @default(0)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  buyer    User          @relation("BuyerSessions", fields: [buyerId], references: [id], onDelete: Restrict)
  farmer   User          @relation("FarmerSessions", fields: [farmerId], references: [id], onDelete: Restrict)
  product  Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
  messages ChatMessage[]
  proposals PriceProposal[]
  orders   Order[]

  @@unique([buyerId, farmerId, productId])
  @@index([buyerId])
  @@index([farmerId])
  @@map("negotiation_sessions")
}

model ChatMessage {
  id                    String      @id @default(uuid())
  sessionId             String
  senderId              String
  senderRole            Role
  type                  MessageType @default(TEXT)
  text                  String?
  voiceNoteUrl          String?
  voiceNoteDurationSecs Int?
  imageUrl              String?
  priceProposalId       String?
  readByRecipient       Boolean     @default(false)
  createdAt             DateTime    @default(now())

  session       NegotiationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sender        User               @relation("SentMessages", fields: [senderId], references: [id], onDelete: Restrict)
  priceProposal PriceProposal?     @relation(fields: [priceProposalId], references: [id])

  @@index([sessionId, createdAt])
  @@map("chat_messages")
}

model PriceProposal {
  id              String         @id @default(uuid())
  sessionId       String
  proposedByUserId String
  proposedBy      Role
  proposedPrice   Decimal        @db.Decimal(10, 2)
  proposedQuantity Int
  note            String?
  status          ProposalStatus @default(PENDING)
  expiresAt       DateTime
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  session      NegotiationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  messages     ChatMessage[]

  @@index([sessionId])
  @@map("price_proposals")
}

model Order {
  id                      String        @id @default(uuid())
  orderNumber             String        @unique
  sessionId               String
  buyerId                 String
  farmerId                String
  addressId               String?
  deliveryAddressSnapshot Json
  quantity                Int
  pricePerUnit            Decimal       @db.Decimal(10, 2)
  subtotal                Decimal       @db.Decimal(10, 2)
  platformFee             Decimal       @db.Decimal(10, 2)
  totalAmount             Decimal       @db.Decimal(10, 2)
  status                  OrderStatus   @default(PENDING)
  paymentMethod           PaymentMethod
  paymentStatus           PaymentStatus @default(PENDING)
  stripePaymentIntentId   String?
  flutterwaveTxRef        String?
  deliveryDate            DateTime?
  placedAt                DateTime      @default(now())
  confirmedAt             DateTime?
  dispatchedAt            DateTime?
  deliveredAt             DateTime?
  cancelledAt             DateTime?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  session NegotiationSession @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  buyer   User               @relation("BuyerOrders", fields: [buyerId], references: [id], onDelete: Restrict)
  farmer  User               @relation("FarmerOrders", fields: [farmerId], references: [id], onDelete: Restrict)
  address Address?           @relation(fields: [addressId], references: [id])
  review  Review?

  @@index([buyerId])
  @@index([farmerId])
  @@index([status])
  @@map("orders")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model Review {
  id         String   @id @default(uuid())
  orderId    String   @unique
  reviewerId String
  farmerId   String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  order    Order @relation(fields: [orderId], references: [id], onDelete: Restrict)
  reviewer User  @relation(fields: [reviewerId], references: [id], onDelete: Restrict)

  @@index([farmerId])
  @@map("reviews")
}

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model EmailVerification {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verifications")
}

model PasswordReset {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("device_tokens")
}
